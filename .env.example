# =====================================================
# SATAN6X6 PUBLIC BOT — Environment Variables
# 
# Built with OpenClaw (https://openclaw.ai)
# Powered by Anthropic Claude Sonnet 4.6
# 
# Copy this file to .env and fill with real values:
#   cp .env.example .env
#   nano .env
# =====================================================


# ─── REQUIRED ────────────────────────────────────────

# Telegram Bot Token
# Get from @BotFather on Telegram: https://t.me/BotFather
PUBLIC_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic Claude API Key — powers the AI conversation
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# Solana wallet address for receiving Premium subscription payments
# Use a dedicated wallet, NOT your main treasury wallet
SUBSCRIPTION_WALLET=YourSolanaWalletAddressHere

# Helius RPC API key — for Solana mainnet RPC calls
# Free tier available at: https://helius.dev
HELIUS_API_KEY=your_helius_api_key

# Twitter API v1.1 OAuth credentials
# Apply at: https://developer.twitter.com
TWITTER_APP_KEY=your_app_key
TWITTER_APP_SECRET=your_app_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret


# ─── OPTIONAL ────────────────────────────────────────

# Twitter API v2 Bearer Token
# Preferred for search/timeline endpoints (more reliable than OAuth)
TWITTER_BEARER_TOKEN=your_bearer_token

# Owner Telegram User ID — only this user can run /stats admin command
# Get yours from @userinfobot on Telegram
OWNER_TELEGRAM_ID=

# Custom data directory for stats files (default: same dir as bot)
# DATA_DIR=/path/to/data

# Custom .env file path (default: ./env)
# DOTENV_PATH=/path/to/.env


# =====================================================
# 🛡️ SECURITY NOTES
# =====================================================
# - NEVER commit .env to GitHub (already in .gitignore)
# - Each developer must obtain their own credentials
# - Bot will refuse to start if required vars are missing
# - Twitter API has rate limits; use Bearer token if possible
# - Rotate API keys periodically for security
# =====================================================


